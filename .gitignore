# ============================================================
# BLACKSITE NODE — .gitignore
# CRITICAL: Vault files must NEVER be committed to any VCS.
# A committed vault file exposes the encrypted blob to offline
# brute-force attacks with unlimited time and compute.
# ============================================================

# --- Vault files (the entire threat surface) ---
*.blacksite
*.blacksite.bak
vault.json
*.vault
test_vault*/

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Node / npm ---
node_modules/
dist/
dist-ssr/
*.local

# --- Rust / Cargo build artifacts ---
src-tauri/target/
src-tauri/Cargo.lock
Cargo.lock.bak

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Editor directories ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS artifacts ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
